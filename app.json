{
  "expo": {
    "name": "smart-home-app",
    "slug": "smart-home-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.smarthomeapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
          "react-native-voicekit",
          {
          "speechRecognitionPermission": "Cho phép Smart Home App nhận dạng giọng nói để xử lý lệnh điều khiển nhà thông minh.",
          "microphonePermission": "Cho phép Smart Home App sử dụng microphone để ghi nhận lệnh giọng nói."
        }
      ]
    ]
  }
}
