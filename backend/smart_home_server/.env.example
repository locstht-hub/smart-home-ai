# Smart Home Server environment example.
# Copy this file to .env for local use, but never commit .env.

# Leave DATABASE_URL empty to keep using local SQLite.
# Set it to a Supabase/Postgres connection string to use cloud storage.
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-...pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional API token for protecting /api/* endpoints.
# SMART_HOME_API_TOKEN=change-this-long-random-token

# Optional assistant provider keys. Keep real keys only in local env files.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# SMART_HOME_ASSISTANT_PROVIDER=mock
