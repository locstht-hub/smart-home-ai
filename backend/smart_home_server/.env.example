# Smart Home Server environment example.
# Copy this file to .env for local use, but never commit .env.

# Leave DATABASE_URL empty to keep using local SQLite.
# Set it to a Supabase/Postgres connection string to use cloud storage.
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-...pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Example for this project's Supabase pooler. Replace <password> locally.
# DATABASE_URL=postgresql://postgres.bnoiukpmkcxudiqoyise:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Optional API token for protecting /api/* endpoints.
# SMART_HOME_API_TOKEN=change-this-long-random-token

# Dedicated credential for POST /api/power/readings. When empty, telemetry
# ingestion stays locked. Do not reuse a mobile-user or admin token.
# SMART_HOME_TELEMETRY_TOKEN=change-this-separate-long-random-token

# Auto load shedding is fail-closed by default. Enable only after physical
# interlocks, essential-load exclusions and feedback tests are complete.
# SMART_HOME_AUTO_LOAD_SHEDDING_ENABLED=false

# Demo bootstrap is opt-in for a brand-new empty database. Never commit real
# passwords, and rotate any previously seeded default credentials.
# SMART_HOME_SEED_DEMO_USERS=false
# SMART_HOME_BOOTSTRAP_ADMIN_PASSWORD=
# SMART_HOME_BOOTSTRAP_OWNER_PASSWORD=
# SMART_HOME_BOOTSTRAP_MEMBER_PASSWORD=

# Optional assistant provider keys. Keep real keys only in local env files.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# SMART_HOME_ASSISTANT_PROVIDER=mock
