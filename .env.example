# Local demo authentication is disabled by default and only honored in a
# development build. Production users must authenticate against the server.
EXPO_PUBLIC_ALLOW_LOCAL_DEMO_AUTH=false

# Optional development-only demo credentials. Values prefixed EXPO_PUBLIC are
# embedded in the client bundle, so never treat them as secrets.
EXPO_PUBLIC_DEMO_ADMIN_PASSWORD=
EXPO_PUBLIC_DEMO_USER_PASSWORD=
